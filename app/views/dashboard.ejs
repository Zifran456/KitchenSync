<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KitchenSync - Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>

  <div class="page-wrapper">

    <!-- TOP NAV -->
    <div class="top-nav">
      <div class="top-nav-left">
        <a href="/" class="ks-logo" style="font-size:1.4rem;">KS</a>
        <div class="user-avatar" style="margin-left:0.75rem;">
          <i class="bi bi-person-fill" style="font-size:1.4rem; color:#999;"></i>
        </div>
        <span class="username"><%= username %></span>
      </div>
      <div class="top-nav-right">
        <a href="/add-item" class="icon-btn" title="Add Item">
          <i class="bi bi-plus-lg"></i>
        </a>
        <a href="/liked-recipes" class="icon-btn" title="Liked Recipes">
          <i class="bi bi-suit-heart-fill"></i>
        </a>

        <!-- NOTIFICATION BELL -->
        <div class="notif-wrapper">
          <button class="icon-btn notif-bell-btn" id="notifBell" title="Notifications" type="button">
            <i class="bi bi-bell-fill" style="color:#2C2C2C;"></i>
            <% var notifTotal = expiring.length + expired.length; %>
            <% if (notifTotal > 0) { %>
              <span class="notif-count"><%= notifTotal %></span>
            <% } %>
          </button>
          <div class="notif-panel" id="notifPanel">
            <div class="notif-panel-header">Notifications</div>
            <% if (notifTotal === 0) { %>
              <div class="notif-empty">You're all caught up in your kitchen!</div>
            <% } else { %>
              <% expiring.forEach(function(item) { %>
                <div class="notif-item notif-item-orange">
                  <i class="bi bi-clock-history"></i>
                  <span>Your <strong><%= item.name %></strong> is expiring soon — <a href="/recipes">see recipe suggestions</a></span>
                </div>
              <% }) %>
              <% expired.forEach(function(item) { %>
                <div class="notif-item notif-item-red">
                  <i class="bi bi-exclamation-circle-fill"></i>
                  <span>Your <strong><%= item.name %></strong> has expired — consider removing them</span>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

        <a href="/auth/logout" class="icon-btn" title="Sign Out">
          <i class="bi bi-box-arrow-right"></i>
        </a>
      </div>
    </div>

    <!-- OVERVIEW CARD -->
    <div class="overview-card">
      <h3>Overview</h3>
      <div class="overview-stats">

        <div class="stat-item">
          <div class="stat-icon total"><i class="bi bi-box-seam"></i></div>
          <span class="stat-number text-blue"><%= totalItems %></span>
          <span class="stat-label">Total Items</span>
        </div>

        <div class="stat-item">
          <div class="stat-icon expired"><i class="bi bi-exclamation-circle"></i></div>
          <span class="stat-number text-red"><%= expiredCount %></span>
          <span class="stat-label">Expired</span>
        </div>

        <div class="stat-item">
          <div class="stat-icon expiring"><i class="bi bi-clock-history"></i></div>
          <span class="stat-number text-orange"><%= expiringSoonCount %></span>
          <span class="stat-label">Expiring Soon</span>
        </div>

        <div class="stat-item">
          <div class="stat-icon low-stock"><i class="bi bi-graph-down-arrow"></i></div>
          <span class="stat-number text-orange-dark"><%= lowStockCount %></span>
          <span class="stat-label">Low Stock</span>
        </div>

      </div>
    </div>

    <!-- FILTER TABS -->
    <div class="filter-tabs">
      <button class="filter-tab active"  data-filter="all">All</button>
      <button class="filter-tab"         data-filter="expired">Expired</button>
      <button class="filter-tab"         data-filter="expiring">Expiring Soon</button>
      <button class="filter-tab"         data-filter="low-stock">Low Stock</button>
    </div>

    <!-- ALL -->
    <div class="items-section filter-content" data-content="all" style="display: block;">
      <h4>All</h4>
      <% if (allItems.length === 0) { %>
        <div class="empty-state">
          <p>No items yet.</p>
          <a href="/add-item" style="color: var(--blue-link);">Add your first item</a>
        </div>
      <% } else { %>
        <div class="items-grid">
          <% allItems.forEach(function(item) { %>
            <div class="item-card <%= item.borderClass %>">
              <div class="item-image">
                <i class="bi bi-image" style="font-size:1.5rem; color:#CCC;"></i>
              </div>
              <div class="item-info">
                <div class="item-name"><%= item.name %></div>
                <div class="item-meta">Qty: <%= item.quantity %><% if (item.expiryFormatted) { %> · Exp: <%= item.expiryFormatted %><% } %></div>
              </div>

              <a href="/items/<%= item._id %>/edit" class="edit-btn" title="Edit item">
                <i class="bi bi-pencil"></i>
              </a>
              <form action="/items/<%= item._id %>?_method=DELETE" method="POST">
                <button type="submit" class="delete-btn" title="Delete item"
                  onclick="return confirm('Delete <%= item.name %>?')">
                  <i class="bi bi-trash"></i>
                </button>
              </form>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- EXPIRED -->
    <div class="items-section filter-content" data-content="expired" style="display: none;">
      <h4>Expired</h4>
      <% if (expired.length === 0) { %>
        <div class="empty-state"><p>No expired items.</p></div>
      <% } else { %>
        <div class="items-grid">
          <% expired.forEach(function(item) { %>
            <div class="item-card border-red">
              <div class="item-image">
                <i class="bi bi-image" style="font-size:1.5rem; color:#CCC;"></i>
              </div>
              <div class="item-info">
                <div class="item-name"><%= item.name %></div>
                <div class="item-meta">Qty: <%= item.quantity %><% if (item.expiryFormatted) { %> · Exp: <%= item.expiryFormatted %><% } %></div>
              </div>

              <a href="/items/<%= item._id %>/edit" class="edit-btn" title="Edit item">
                <i class="bi bi-pencil"></i>
              </a>
              <form action="/items/<%= item._id %>?_method=DELETE" method="POST">
                <button type="submit" class="delete-btn" title="Delete item"
                  onclick="return confirm('Delete <%= item.name %>?')">
                  <i class="bi bi-trash"></i>
                </button>
              </form>
            </div>
          <% }) %>
        </div>
        <div style="margin-top:1rem; padding:0.75rem 1rem; background:#FDE8E8; border:1px solid #F5C2C2; border-radius:8px; color:#B91C1C; font-size:0.875rem;">
          <i class="bi bi-exclamation-triangle-fill" style="margin-right:0.4rem;"></i>
          <strong>These Need to Go!</strong> — consider throwing them away.
        </div>
      <% } %>
    </div>

    <!-- EXPIRING SOON -->
    <div class="items-section filter-content" data-content="expiring" style="display: none;">
      <h4>Expiring Soon</h4>
      <% if (expiring.length === 0) { %>
        <div class="empty-state"><p>No items expiring soon.</p></div>
      <% } else { %>
        <div class="items-grid">
          <% expiring.forEach(function(item) { %>
            <div class="item-card border-orange">
              <div class="item-image">
                <i class="bi bi-image" style="font-size:1.5rem; color:#CCC;"></i>
              </div>
              <div class="item-info">
                <div class="item-name"><%= item.name %></div>
                <div class="item-meta">Qty: <%= item.quantity %><% if (item.expiryFormatted) { %> · Exp: <%= item.expiryFormatted %><% } %></div>
              </div>

              <a href="/items/<%= item._id %>/edit" class="edit-btn" title="Edit item">
                <i class="bi bi-pencil"></i>
              </a>
              <form action="/items/<%= item._id %>?_method=DELETE" method="POST">
                <button type="submit" class="delete-btn" title="Delete item"
                  onclick="return confirm('Delete <%= item.name %>?')">
                  <i class="bi bi-trash"></i>
                </button>
              </form>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- LOW STOCK -->
    <div class="items-section filter-content" data-content="low-stock" style="display: none;">
      <h4>Low Stock</h4>
      <% if (lowStock.length === 0) { %>
        <div class="empty-state"><p>No low stock items.</p></div>
      <% } else { %>
        <div class="items-grid">
          <% lowStock.forEach(function(item) { %>
            <div class="item-card <%= item.borderClass %>">
              <div class="item-image">
                <i class="bi bi-image" style="font-size:1.5rem; color:#CCC;"></i>
              </div>
              <div class="item-info">
                <div class="item-name"><%= item.name %></div>
                <div class="item-meta">Qty: <%= item.quantity %><% if (item.expiryFormatted) { %> · Exp: <%= item.expiryFormatted %><% } %></div>
              </div>

              <a href="/items/<%= item._id %>/edit" class="edit-btn" title="Edit item">
                <i class="bi bi-pencil"></i>
              </a>
              <form action="/items/<%= item._id %>?_method=DELETE" method="POST">
                <button type="submit" class="delete-btn" title="Delete item"
                  onclick="return confirm('Delete <%= item.name %>?')">
                  <i class="bi bi-trash"></i>
                </button>
              </form>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- RECIPE SUGGESTIONS -->
    <div class="recipe-suggestions">
      <h4>Recipe Suggestions</h4>
      <% if (topRecipes.length === 0) { %>
        <p style="font-size:0.85rem; color:#888; margin: 0.5rem 0 0;">
          Add items to your storage to see recipe suggestions.
        </p>
      <% } else { %>
        <div class="recipe-grid">
          <% topRecipes.forEach(function(recipe) { %>
            <div class="recipe-card" style="border: 1.5px solid <%= recipe.hasExpiring ? 'var(--orange-expiring)' : 'var(--border-gray)' %>; background: <%= recipe.hasExpiring ? '#FFF8EC' : 'var(--white)' %>;">
              <div class="recipe-card-image">
                <i class="bi bi-image" style="font-size:2rem; color:#CCC;"></i>
              </div>
              <div class="recipe-card-info">
                <h5 style="margin:0 0 0.2rem; font-size:1rem;"><%= recipe.name %></h5>
                <p style="font-size:0.8rem; color:#666; margin-bottom:0.4rem; line-height:1.4;"><%= recipe.description %></p>
                <div style="margin-bottom:0.5rem;">
                  <% recipe.matchedItems.forEach(function(item) { %>
                    <span style="display:inline-block; border-radius:20px; font-size:0.72rem; padding:2px 8px; margin:2px 2px 0 0; font-weight:500;
                      background:<%= item.status === 'expiring' ? '#FEF3E2' : '#EAF4EB' %>;
                      color:<%= item.status === 'expiring' ? '#B7600A' : 'var(--green-add)' %>;
                      border: 1px solid <%= item.status === 'expiring' ? '#F9D89A' : '#A8D5AB' %>;">
                      <%= item.name %>
                    </span>
                  <% }) %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
        <div style="text-align:right; margin-top:0.75rem;">
          <a href="/recipes" style="font-size:0.85rem; color:var(--blue-link); text-decoration:none;">
            View all recipes <i class="bi bi-arrow-right"></i>
          </a>
        </div>
      <% } %>
    </div>

    <!-- STORAGE SECTION -->
    <div class="storage-section" id="storage-section">
      <h4>Storages</h4>
      <div class="storage-grid">

        <div class="storage-item-wrapper">
          <a href="/fridge" class="storage-item">
            <div class="storage-icon"><i class="bi bi-door-closed"></i></div>
            <span class="storage-label">Fridge</span>
          </a>
        </div>

        <div class="storage-item-wrapper">
          <a href="/pantry" class="storage-item">
            <div class="storage-icon"><i class="bi bi-basket"></i></div>
            <span class="storage-label">Pantry</span>
          </a>
        </div>

        <div class="storage-item-wrapper">
          <a href="/freezer" class="storage-item">
            <div class="storage-icon"><i class="bi bi-archive"></i></div>
            <span class="storage-label">Freezer</span>
          </a>
        </div>

        <% customStorages.forEach(function(s) { %>
        <div class="storage-item-wrapper">
          <a href="/storage/<%= s._id %>" class="storage-item">
            <div class="storage-icon"><i class="bi bi-box-seam"></i></div>
            <span class="storage-label"><%= s.name %></span>
          </a>
        </div>
        <% }) %>

        <div class="storage-item-wrapper">
          <a href="#" class="storage-item" data-bs-toggle="modal" data-bs-target="#addStorageModal">
            <div class="storage-icon"><i class="bi bi-plus-lg"></i></div>
            <span class="storage-label">Add New</span>
          </a>
        </div>

      </div>
    </div>

  </div>

  <!-- ADD STORAGE MODAL -->
  <div class="modal fade" id="addStorageModal" tabindex="-1" aria-labelledby="addStorageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 340px;">
      <div class="modal-content" style="border-radius: 16px; border: none; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">
        <div class="modal-header" style="border-bottom: 1px solid #EDE8D6; padding: 1.25rem 1.5rem 1rem 1.5rem;">
          <h5 class="modal-title" id="addStorageModalLabel" style="font-weight: 700; color: #2C2C2C; font-size: 1.1rem;">New Storage</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form action="/storages" method="POST">
          <div class="modal-body" style="padding: 1.25rem 1.5rem;">
            <label for="storageNameInput" style="font-size: 0.9rem; font-weight: 600; color: #2C2C2C; display: block; margin-bottom: 0.5rem;">Storage Name</label>
            <input type="text" id="storageNameInput" name="name" placeholder="e.g. Garage Freezer" required
              style="width:100%; padding:0.7rem 1rem; border:1px solid #D5D5D5; border-radius:8px; font-size:0.95rem; color:#2C2C2C; background-color:#FFF; outline:none;">
          </div>
          <div class="modal-footer" style="border-top: 1px solid #EDE8D6; padding: 1rem 1.5rem; gap: 0.5rem;">
            <button type="button" data-bs-dismiss="modal" style="background-color:#F5F0E1; color:#2C2C2C; border:1px solid #D5D5D5; border-radius:8px; padding:0.6rem 1.2rem; font-size:0.9rem; cursor:pointer;">Cancel</button>
            <button type="submit" style="background-color:#D4A843; color:#FFF; border:none; border-radius:8px; padding:0.6rem 1.4rem; font-size:0.9rem; font-weight:600; cursor:pointer;">Add Storage</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
