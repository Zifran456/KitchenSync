<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KitchenSync - Edit Item</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>

  <div class="page-wrapper">

    <div class="inner-header">
      <a href="<%= back %>" class="back-link"><i class="bi bi-arrow-left"></i> Back</a>
      <span></span>
      <a href="/dashboard" class="home-link"><i class="bi bi-house-fill"></i></a>
    </div>

    <div class="add-item-page">
      <h3>Edit Item</h3>

      <% if (error) { %>
        <div class="alert-msg alert-error"><%= error %></div>
      <% } %>

      <form action="/items/<%= item._id %>?_method=PUT" method="POST">

        <div class="image-placeholder">
          <i class="bi bi-image"></i>
        </div>

        <label for="itemName">Item Name</label>
        <input type="text" class="form-control" id="itemName" name="itemName"
          placeholder="Enter item name" value="<%= item.name %>" required>

        <label>Quantity</label>
        <div class="quantity-control">
          <button type="button" class="quantity-btn" id="quantityMinus">&minus;</button>
          <input type="text" class="quantity-value" id="quantityValue" name="quantity"
            value="<%= item.quantity %>" readonly>
          <button type="button" class="quantity-btn plus" id="quantityPlus">+</button>
        </div>

        <div class="assign-options">
          <span>Storage</span>
          <button type="button" class="assign-btn <%= item.storage === 'Pantry'  ? 'active' : '' %>">Pantry</button>
          <button type="button" class="assign-btn <%= item.storage === 'Fridge'  ? 'active' : '' %>">Fridge</button>
          <button type="button" class="assign-btn <%= item.storage === 'Freezer' ? 'active' : '' %>">Freezer</button>
          <% customStorages.forEach(function(s) { %>
            <button type="button" class="assign-btn <%= item.storage === s.name ? 'active' : '' %>"><%= s.name %></button>
          <% }) %>
        </div>
        <input type="hidden" id="storageValue" name="storage" value="<%= item.storage %>">

        <label for="expiryDate">Expiration Date</label>
        <input type="date" class="form-control <%= expiryValue ? '' : 'date-empty' %>"
          id="expiryDate" name="expiryDate" value="<%= expiryValue %>" required>

        <input type="hidden" name="back" value="<%= back %>">

        <button type="submit" class="btn-add-item">Save Changes</button>

      </form>
    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
