<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KitchenSync - Freezer</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

  <link href="css/style.css" rel="stylesheet">
</head>

<body>

  <div class="page-wrapper">

    <div class="inner-header">
      <a href="/dashboard" class="back-link">
        <i class="bi bi-arrow-left"></i> Back
      </a>
      <span class="inner-title">Freezer</span>
      <a href="/dashboard" class="home-link">
        <i class="bi bi-house-fill"></i>
      </a>
    </div>

    <div class="search-bar" style="justify-content: flex-end;">
      <div class="search-input-wrapper" style="width: 260px;">
        <input type="text" placeholder="Search items..." class="page-search-input" data-target="#freezerItems" style="
            width: 100%;
            padding: 0.7rem 2.5rem 0.7rem 1rem;
            border: 1px solid var(--border-gray);
            border-radius: 8px;
            font-size: 0.9rem;
            background-color: var(--white);
          ">
        <span class="search-icon-inside">
          <i class="bi bi-search"></i>
        </span>
      </div>
      <a href="/add-item" class="add-item-btn">
        <i class="bi bi-plus-lg"></i>
      </a>
    </div>

    <div id="freezerItems">
      <% if (!foods || foods.length===0) { %>
        <div class="empty-state">
          <i class="bi bi-snow" style="font-size:3rem; margin-bottom:0.5rem;"></i>
          <p>No items in your freezer yet.</p>
          <a href="/add-item" style="color: var(--blue-link);">Add your first item</a>
        </div>
        <% } else { %>
          <div class="items-grid">
            <% foods.forEach(food=> { %>
              <div class="item-card searchable-item">
                <div class="item-image">
                  <% if (food.imageUrl) { %>
                    <img src="<%= food.imageUrl %>" alt="<%= food.name %>"
                      style="width:100%; height:100%; object-fit:cover; border-radius:12px;">
                    <% } else { %>
                      <i class="bi bi-image" style="font-size:1.5rem; color:#CCC;"></i>
                      <% } %>
                </div>

                <div class="item-info">
                  <div class="item-name">
                    <%= food.name %>
                  </div>
                  <div class="item-quantity">Qty: <%= food.quantity %>
                  </div>
                </div>

                <div class="item-time">
                  <%= new Date(food.expiryDate).toLocaleDateString() %>
                </div>

                <div style="margin-top:8px; display:flex; gap:6px; flex-wrap:wrap;">
                  <form action="/decrease-quantity" method="POST">
                    <input type="hidden" name="foodId" value="<%= food._id %>">
                    <button type="submit" class="btn btn-sm btn-warning">
                      <i class="bi bi-dash-lg"></i>
                    </button>
                  </form>

                  <form action="/delete-item" method="POST">
                    <input type="hidden" name="foodId" value="<%= food._id %>">
                    <button type="submit" class="btn btn-sm btn-danger"
                      onclick="return confirm('Are you sure you want to remove this item?')">
                      Remove
                    </button>
                  </form>
                </div>
              </div>
              <% }) %>
          </div>
          <% } %>
    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
  </script>

  <script src="js/app.js"></script>

</body>

</html>