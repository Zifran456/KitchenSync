<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Recipe Suggestions</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

  <style>
    body {
      background: #f5f7fb;
    }
  </style>
  <link href="/css/style.css" rel="stylesheet">
</head>

<body>
  <div class="container py-4">

    <div class="page-wrapper">

      <div class="inner-header">
        <a href="/dashboard" class="back-link">
          <i class="bi bi-arrow-left"></i> Back
        </a>


        <div>
          <h2 class="fw-bold">Recipe Suggestions</h2>
          <p class="text-muted mb-0">Recipes generated from your ingredients</p>
        </div>
        <a href="/dashboard" class="home-link">
          <i class="bi bi-house-fill"></i>
        </a>
      </div>
      <div class="recipe-grid">
        <% recipes.forEach(recipe=> { %>
          <div class="recipe-card">
            <img src="<%= recipe.image %>" alt="<%= recipe.title %>">

            <div class="recipe-content">
              <h5>
                <%= recipe.title %>
              </h5>

              <div class="recipe-meta">
                <p class="mb-2"><strong>Ingredients:</strong></p>
                <ul>
                  <% recipe.ingredients.forEach(ingredient=> { %>
                    <li>
                      <%= ingredient %>
                    </li>
                    <% }) %>
                </ul>

                <p class="mb-2"><strong>How to make it:</strong></p>
                <p>
                  <%= recipe.instructions %>
                </p>
              </div>

              <div class="recipe-actions">
                <form action="/recipes/save" method="POST" class="w-100">
                  <input type="hidden" name="title" value="<%= recipe.title %>">
                  <input type="hidden" name="image" value="<%= recipe.image %>">
                  <input type="hidden" name="instructions" value="<%= recipe.instructions %>">

                  <% recipe.ingredients.forEach(ingredient=> { %>
                    <input type="hidden" name="ingredients" value="<%= ingredient %>">
                    <% }) %>

                      <button type="submit" class="btn btn-success btn-sm w-100">
                        <i class="bi bi-bookmark-heart"></i> Save
                      </button>
                </form>
              </div>
            </div>
          </div>
          <% }) %>
      </div>
    </div>
</body>

</html>