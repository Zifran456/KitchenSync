<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KitchenSync - Add New Item</title>


  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="css/style.css" rel="stylesheet">
</head>

<body>

  <div class="page-wrapper">


    <div class="inner-header">
      <a href="/dashboard" class="back-link">
        <i class="bi bi-arrow-left"></i> Back
      </a>
      <span></span>
      <a href="/dashboard" class="home-link">
        <i class="bi bi-house-fill"></i>
      </a>
    </div>


    <div class="add-item-page">
      <h3>Add New</h3>

      <form id="addItemForm" action="/addItemForm" method="POST">

        <div class="image-placeholder" id="imagePreview">
          <i class="bi bi-image"></i>
        </div>
        <input type="hidden" name="imageUrl" id="imageUrl">

        <label for="itemName">Item Name</label>
        <input type="text" name="name" class="form-control" id="itemName" placeholder="Enter item name" required>


        <label>Quantity</label>
        <div class="quantity-control">
          <button type="button" class="quantity-btn" id="quantityMinus">&minus;</button>
          <input type="text" name="quantity" class="quantity-value" id="quantityValue" value="1" readonly>
          <button type="button" class="quantity-btn plus" id="quantityPlus">+</button>
        </div>


        <div class="assign-options">
          <span>Assign to</span>
          <button type="button" class="assign-btn">Pantry</button>
          <button type="button" class="assign-btn">Fridge</button>
          <button type="button" class="assign-btn">Freezer</button>
        </div>
        <input type="hidden" name="storage" id="storageValue">

        <div class="mb-3">
          <input type="date" class="form-control" id="expiryDate" name="expiryDate" placeholder="Expiry Date"
            style="padding: 0.8rem;">
        </div>


        <button type="submit" class="btn-add-item">
          Add item
        </button>

      </form>

    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
  </script>


  <script src="js/app.js"></script>

</body>

</html>