<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KitchenSync - Recipes</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

  <link href="/css/style.css" rel="stylesheet">
</head>

<body>

  <div class="page-wrapper">

    <div class="inner-header">
      <a href="/dashboard" class="back-link">
        <i class="bi bi-arrow-left"></i> Back
      </a>
      <span class="inner-title">Recipes</span>
      <a href="/dashboard" class="home-link">
        <i class="bi bi-house-fill"></i>
      </a>
    </div>

    <div class="search-bar" style="justify-content: flex-end;">
      <div class="search-input-wrapper" style="width: 260px;">
        <input type="text" placeholder="Search recipes" class="page-search-input" data-target="#recipeList" style="
            width: 100%;
            padding: 0.7rem 2.5rem 0.7rem 1rem;
            border: 1px solid var(--border-gray);
            border-radius: 8px;
            font-size: 0.9rem;
            background-color: var(--white);
          ">
        <span class="search-icon-inside">
          <i class="bi bi-search"></i>
        </span>
      </div>
    </div>

    <div class="recipe-list" id="recipeList">

      <% if (!recipes || recipes.length===0) { %>
        <div class="empty-state">
          <i class="bi bi-journal-richtext" style="font-size:3rem; margin-bottom:0.5rem;"></i>
          <p>No recipes added yet.</p>
          <a href="/add-recipe" style="color: var(--blue-link);">Add your first recipe</a>
        </div>
        <% } else { %>

          <div class="recipe-grid">
            <% recipes.forEach(recipe=> { %>
              <div class="recipe-card searchable-item">

                <div class="recipe-card-image">
                  <% if (recipe.image) { %>
                    <img src="<%= recipe.image %>" alt="<%= recipe.title %>"
                      style="width:100%; height:100%; object-fit:cover; border-radius:12px;">
                    <% } else { %>
                      <i class="bi bi-image" style="font-size:2rem; color:#CCC;"></i>
                      <% } %>
                </div>

                <div class="recipe-card-info">

                  <h5>
                    <%= recipe.title %>
                  </h5>
                  <p>
                    <%= recipe.ingredients.length %> ingredients
                  </p>

                  <!-- Learn More Expand -->
                  <details style="margin-top:8px;">
                    <summary class="btn-learn-more learn-toggle">
                      Learn more
                    </summary>

                    <div style="margin-top:10px; background:#f8f9fa; padding:12px; border-radius:12px;">

                      <h6>Ingredients</h6>
                      <ul style="padding-left:20px; margin-bottom:10px;">
                        <% recipe.ingredients.forEach(ingredient=> { %>
                          <li>
                            <%= ingredient %>
                          </li>
                          <% }) %>
                      </ul>

                      <h6>Instructions</h6>
                      <p style="margin-bottom:0;">
                        <%= recipe.instructions %>
                      </p>

                    </div>
                  </details>


                  <form action="/like-recipe" method="POST" style="margin-top:8px;">
                    <input type="hidden" name="recipeId" value="<%= recipe._id %>">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                      <i class="bi bi-heart"></i> Save to Favorites
                    </button>
                  </form>
                  <form action="/delete-recipe" method="POST" style="margin-top:8px;">
                    <input type="hidden" name="recipeId" value="<%= recipe._id %>">
                    <button type="submit" class="btn btn-sm btn-danger"
                      onclick="return confirm('Are you sure you want to remove this recipe?')">
                      Remove Recipe
                    </button>
                  </form>
                </div>
              </div>
              <% }) %>
          </div>

          <% } %>

    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
  <script>
    document.querySelectorAll("details").forEach(detail => {
      const summary = detail.querySelector(".learn-toggle");

      detail.addEventListener("toggle", () => {
        if (detail.open) {
          summary.textContent = "Close";
        } else {
          summary.textContent = "Learn more";
        }
      });
    });
  </script>

</body>

</html>