<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KitchenSync - Welcome</title>

  <!-- Bootstrap 5 CSS (loaded from CDN) -->
  <link 
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" 
    rel="stylesheet"
  >

  <!-- Bootstrap Icons -->
  <link 
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" 
    rel="stylesheet"
  >

  <!-- Our Custom CSS -->
  <link href="css/style.css" rel="stylesheet">
</head>
<body style="background-color: #000;">

  <!-- Page Wrapper (keeps content centered like a mobile screen) -->
  <div class="page-wrapper" style="background-color: #000;">

    <!-- KS Logo in top-left corner -->
    <div style="position: absolute; top: 1rem; left: 1rem; z-index: 10;">
      <span class="ks-logo" style="color: #D4A843;">KS</span>
    </div>

    <!-- Welcome Screen Content -->
    <div class="welcome-page">

      <!-- Circle with Title -->
      <div class="welcome-circle">
        <h1>Welcome<br>to<br>KitchenSync</h1>
      </div>

      <!-- Tagline -->
      <p class="welcome-tagline">Your Kitchen,<br>Connected</p>

      <!-- Get Started Button (links to login page) -->
      <a href="login.html" class="btn-get-started">
        Get Started &rarr;
      </a>

    </div>
    <!-- End Welcome Screen -->

  </div>
  <!-- End Page Wrapper -->

  <!-- Bootstrap 5 JS Bundle (loaded from CDN) -->
  <script 
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
  </script>

  <!-- Our Custom JS -->
  <script src="js/app.js"></script>

</body>
</html>
