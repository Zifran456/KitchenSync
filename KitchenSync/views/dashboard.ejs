<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KitchenSync - Dashboard</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

  <link href="css/style.css" rel="stylesheet">

</head>

<body>

  <div class="page-wrapper">


    <div class="top-nav">


      <div class="top-nav-left">
        <a href="/dashboard" class="ks-logo" style="font-size:1.4rem;">KS</a>
        <div class="user-avatar">
          <i class="bi bi-person-fill" style="font-size:1.4rem; color:#999;"></i>
        </div>
        <span class="username">
          <%= username %>
        </span>
      </div>


      <div class="top-nav-right">
        <a href="/liked-recipes" class="icon-btn" title="Liked Recipes">
          <i class="bi bi-suit-heart-fill"></i>
        </a>
        <a href="#" class="icon-btn" data-bs-toggle="modal" data-bs-target="#addChoiceModal">
          <i class="bi bi-plus-lg"></i>
        </a>
      </div>

    </div>




    <div class="overview-card">
      <h3>Overview</h3>
      <div class="overview-stats">


        <div class="stat-item">
          <div class="stat-icon total">
            <i class="bi bi-box-seam"></i>
          </div>
          <span class="stat-number text-blue">
            <h2 id="totalItems">0</h2>
          </span>
          <span class="stat-label">Total Items</span>
        </div>


        <div class="stat-item">
          <div class="stat-icon expired">
            <i class="bi bi-exclamation-circle"></i>
          </div>
          <span class="stat-number text-red">
            <h2 id="expiredItems">0</h2>
          </span>
          <span class="stat-label">Expired</span>
        </div>


        <div class="stat-item">
          <div class="stat-icon expiring">
            <i class="bi bi-clock-history"></i>
          </div>
          <span class="stat-number text-orange">
            <h2 id="expiringSoonItems">0</h2>
          </span>
          <span class="stat-label">Expiring Soon</span>
        </div>


        <div class="stat-item">
          <div class="stat-icon low-stock">
            <i class="bi bi-graph-down-arrow"></i>
          </div>
          <span class="stat-number text-orange-dark">
            <h2 id="lowStockItems">0</h2>
          </span>
          <span class="stat-label">Low Stock</span>
        </div>

      </div>
    </div>

    <div class="storage-section">
      <h4>Storages</h4>
      <div class="storage-grid">

        <a href="/fridge" class="storage-item">
          <div class="storage-icon">
            <i class="bi bi-box-seam"></i>
          </div>
          <span class="storage-label">Fridge</span>
        </a>

        <a href="/pantry" class="storage-item">
          <div class="storage-icon">
            <i class="bi bi-grid-3x3-gap"></i>
          </div>
          <span class="storage-label">Pantry</span>
        </a>

        <a href="/freezer" class="storage-item">
          <div class="storage-icon">
            <i class="bi bi-snow"></i>
          </div>
          <span class="storage-label">Freezer</span>
        </a>

        <a href="/recipes" class="storage-item">
          <div class="storage-icon">
            <i class="bi bi-book"></i>
          </div>
          <span class="storage-label">Recipes</span>
        </a>

      </div>
    </div>



    <div class="filter-tabs">
      <button class="filter-tab active" data-filter="all">All</button>
      <button class="filter-tab" data-filter="expired">Expired</button>
      <button class="filter-tab" data-filter="expiring">Expiring Soon</button>
      <button class="filter-tab" data-filter="low-stock">Low Stock</button>
    </div>


    <div class="items-section filter-content" data-content="all" style="display: block;">
      <h4>All</h4>
      <div class="items-grid">

        <% if (foods.length===0) { %>
          <p>No items found.</p>
          <% } %>

            <% foods.forEach((food, index)=> { %>
              <div class="item-card all-item-card <%= index >= 4 ? 'extra-item d-none' : '' %>">
                <div class="item-image">
                  <% if (food.imageUrl) { %>
                    <img src="<%= food.imageUrl %>" alt="<%= food.name %>"
                      style="width:100%; height:100%; object-fit:cover; border-radius:12px;">
                    <% } else { %>
                      <i class="bi bi-image" style="font-size:1.5rem; color:#CCC;"></i>
                      <% } %>
                </div>

                <div class="item-info">
                  <div class="item-name">
                    <%= food.name %>
                  </div>
                </div>

                <div class="item-time">
                  <%= new Date(food.expiryDate).toLocaleDateString() %>
                </div>

                <div style="margin-top:8px; display:flex; gap:6px; flex-wrap:wrap;">
                  <span>Qty: <%= food.quantity %></span>
                  <!-- Remove quantity -->
                  <form action="/decrease-quantity" method="POST">
                    <input type="hidden" name="foodId" value="<%= food._id %>">
                    <button type="submit" class="btn btn-sm btn-warning"><i class="bi bi-arrow-down"></i></button>
                  </form>


                  <form action="/delete-item" method="POST">
                    <input type="hidden" name="foodId" value="<%= food._id %>">
                    <button type="submit" class="btn btn-sm btn-danger"
                      onclick="return confirm('Are you sure you want to remove this item?')">
                      Remove
                    </button>
                  </form>

                </div>
              </div>
              <% }) %>

      </div>

      <% if (foods.length> 4) { %>
        <div style="margin-top:12px;">
          <button id="toggleAllItemsBtn" class="btn btn-sm btn-outline-secondary" type="button">
            Show More
          </button>
        </div>
        <% } %>
    </div>


    <div class="items-section filter-content" data-content="expired" style="display: none;">
      <h4>Expired</h4>
      <div class="items-grid">

        <% let hasExpired=false; %>

          <% foods.forEach(food=> { %>
            <% if (new Date(food.expiryDate) < new Date()) { %>
              <% hasExpired=true; %>

                <div class="item-card border-red">
                  <div class="item-image">
                    <% if (food.imageUrl) { %>
                      <img src="<%= food.imageUrl %>" alt="<%= food.name %>"
                        style="width:100%; height:100%; object-fit:cover; border-radius:12px;">
                      <% } else { %>
                        <i class="bi bi-image" style="font-size:1.5rem; color:#CCC;"></i>
                        <% } %>
                  </div>

                  <div class="item-info">
                    <div class="item-name">
                      <%= food.name %>
                    </div>
                  </div>

                  <div class="item-time">
                    <%= new Date(food.expiryDate).toLocaleDateString() %>
                  </div>

                  <form action="/delete-item" method="POST">
                    <input type="hidden" name="foodId" value="<%= food._id %>">
                    <button type="submit" class="btn btn-sm btn-danger"
                      onclick="return confirm('Are you sure you want to remove this item?')">
                      Remove
                    </button>
                  </form>
                </div>

                <% } %>
                  <% }) %>

                    <% if (!hasExpired) { %>
                      <p>No expired items.</p>
                      <% } %>

      </div>
    </div>



    <div class="items-section filter-content" data-content="expiring" style="display: none;">
      <h4>Expiring Soon</h4>
      <div class="items-grid">

        <% let hasExpiring=false; const today=new Date(); const soon=new Date(); soon.setDate(today.getDate() + 3); %>

          <% foods.forEach(food=> { %>
            <% const expiry=new Date(food.expiryDate); %>

              <% if (expiry>= today && expiry <= soon) { %>
                  <% hasExpiring=true; %>

                    <div class="item-card border-orange">
                      <div class="item-image">
                        <% if (food.imageUrl) { %>
                          <img src="<%= food.imageUrl %>" alt="<%= food.name %>"
                            style="width:100%; height:100%; object-fit:cover; border-radius:12px;">
                          <% } else { %>
                            <i class="bi bi-image" style="font-size:1.5rem; color:#CCC;"></i>
                            <% } %>
                      </div>

                      <div class="item-info">
                        <div class="item-name">
                          <%= food.name %>
                        </div>
                      </div>

                      <div class="item-time">
                        <%= expiry.toLocaleDateString() %>
                      </div>

                      <form action="/delete-item" method="POST">
                        <input type="hidden" name="foodId" value="<%= food._id %>">
                        <button type="submit" class="btn btn-sm btn-danger"
                          onclick="return confirm('Are you sure you want to remove this item?')">
                          Remove
                        </button>
                      </form>
                    </div>

                    <% } %>
                      <% }) %>

                        <% if (!hasExpiring) { %>
                          <p>No expiring soon items.</p>
                          <% } %>

      </div>
    </div>

    <div class="items-section filter-content" data-content="low-stock" style="display: none;">
      <h4>Low Stock</h4>
      <div class="items-grid">

        <% let hasLowStock=false; %>

          <% foods.forEach(food=> { %>
            <% if (food.quantity <=1) { %>
              <% hasLowStock=true; %>

                <div class="item-card border-orange">
                  <div class="item-image">
                    <% if (food.imageUrl) { %>
                      <img src="<%= food.imageUrl %>" alt="<%= food.name %>"
                        style="width:100%; height:100%; object-fit:cover; border-radius:12px;">
                      <% } else { %>
                        <i class="bi bi-image" style="font-size:1.5rem; color:#CCC;"></i>
                        <% } %>
                  </div>

                  <div class="item-info">
                    <div class="item-name">
                      <%= food.name %>
                    </div>
                  </div>

                  <div class="item-time">
                    Qty: <%= food.quantity %>
                  </div>

                  <form action="/delete-item" method="POST">
                    <input type="hidden" name="foodId" value="<%= food._id %>">
                    <button type="submit" class="btn btn-sm btn-danger"
                      onclick="return confirm('Are you sure you want to remove this item?')">
                      Remove
                    </button>
                  </form>
                </div>

                <% } %>
                  <% }) %>

                    <% if (!hasLowStock) { %>
                      <p>No low stock items.</p>
                      <% } %>

      </div>
    </div>

    <div class="recipe-suggestions-card">
      <div class="recipe-suggestions-header">
        <div>
          <h4 class="mb-1">Recipe Suggestions</h4>
          <p class="text-muted mb-0">Ideas based on your available ingredients</p>
        </div>

        <a href="/recipe-suggestions" class="view-all-btn">
          View All <i class="bi bi-arrow-right"></i>
        </a>
      </div>

      <div class="recipe-scroll" id="recipeSuggestionsGrid">
        <p>Loading recipes...</p>
      </div>
    </div>

  </div>

  <div class="modal fade" id="addStorageModal" tabindex="-1" aria-labelledby="addStorageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 340px;">
      <div class="modal-content"
        style="border-radius: 16px; border: none; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">

        ]
        <div class="modal-header" style="border-bottom: 1px solid #EDE8D6; padding: 1.25rem 1.5rem 1rem 1.5rem;">
          <h5 class="modal-title" id="addStorageModalLabel"
            style="font-weight: 700; color: #2C2C2C; font-size: 1.1rem;">
            New Storage
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>


        <div class="modal-body" style="padding: 1.25rem 1.5rem;">
          <label for="storageNameInput"
            style="font-size: 0.9rem; font-weight: 600; color: #2C2C2C; display: block; margin-bottom: 0.5rem;">
            Storage Name
          </label>
          <input type="text" id="storageNameInput" placeholder="e.g. Garage Freezer" style="
              width: 100%;
              padding: 0.7rem 1rem;
              border: 1px solid #D5D5D5;
              border-radius: 8px;
              font-size: 0.95rem;
              color: #2C2C2C;
              background-color: #FFFFFF;
              outline: none;
            ">
        </div>


        <div class="modal-footer" style="border-top: 1px solid #EDE8D6; padding: 1rem 1.5rem; gap: 0.5rem;">
          <button type="button" data-bs-dismiss="modal" style="
            background-color: #F5F0E1;
            color: #2C2C2C;
            border: 1px solid #D5D5D5;
            border-radius: 8px;
            padding: 0.6rem 1.2rem;
            font-size: 0.9rem;
            cursor: pointer;
          ">
            Cancel
          </button>
          <button type="button" style="
            background-color: #D4A843;
            color: #FFFFFF;
            border: none;
            border-radius: 8px;
            padding: 0.6rem 1.4rem;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
          ">
            Add Storage
          </button>
        </div>

      </div>
    </div>
  </div>


  <div class="modal fade" id="addChoiceModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:300px;">
      <div class="modal-content" style="border-radius:16px;">

        <div class="modal-header">
          <h5 class="modal-title">Add New</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <div class="modal-body" style="display:flex; flex-direction:column; gap:10px;">

          <a href="/add-item" class="btn btn-primary">
            <i class="bi bi-box-seam"></i> Add Food Item
          </a>

          <a href="/add-recipe" class="btn btn-success">
            <i class="bi bi-journal-text"></i> Add Recipe
          </a>

        </div>

      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const toggleBtn = document.getElementById("toggleAllItemsBtn");
      const extraItems = document.querySelectorAll(".all-item-card.extra-item");

      if (!toggleBtn) return;

      let expanded = false;

      toggleBtn.addEventListener("click", function () {
        expanded = !expanded;

        extraItems.forEach(item => {
          if (expanded) {
            item.classList.remove("d-none");
          } else {
            item.classList.add("d-none");
          }
        });

        toggleBtn.textContent = expanded ? "Show Less" : "Show More";
      });
    });
  </script>

  <script src="/js/app.js"></script>



</body>

</html>